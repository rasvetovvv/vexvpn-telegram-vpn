# ─── Telegram ───────────────────────────────────────────────
# Токен бота от @BotFather
BOT_TOKEN=123456789:AAExxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Telegram ID администраторов через запятую (узнать у @userinfobot)
ADMIN_IDS=123456789
# Супер-админы (удаление пользователей, возврат Stars). Пусто = все админы super
SUPER_ADMIN_IDS=
# Опционально: DSN Sentry для трекинга ошибок (нужен пакет sentry-sdk)
SENTRY_DSN=

# ─── База данных ────────────────────────────────────────────
# При запуске через docker-compose хост = db
DATABASE_URL=postgresql+asyncpg://vpnbot:vpnbot@db:5432/vpnbot

# ─── Marzban API ────────────────────────────────────────────
# Адрес панели Marzban (без / в конце)
MARZBAN_BASE_URL=https://vpn.example.com
MARZBAN_USERNAME=admin
MARZBAN_PASSWORD=changeme
# Протоколы прокси через запятую: vless,vmess,trojan
MARZBAN_PROXIES=vless
# flow для vless reality (оставь пустым если не нужен)
MARZBAN_FLOW=xtls-rprx-vision

# ─── Прочее ─────────────────────────────────────────────────
# Username поддержки без @
SUPPORT_USERNAME=yoursupport
# Текст под заголовком (кол-во активных серверов и т.п.)
SERVERS_ONLINE=12
# Username бота без @ для Mini App ссылок
BOT_USERNAME=VexDevVPNbot
# Публичный URL Telegram Mini App
MINI_APP_URL=https://proxy.vexory.xyz
